# Server Configuration
PORT=3000
BASE_URL=http://localhost:3000

# Database
MONGO_URI=mongodb://localhost:2017/your_database_name

# Authentication
JWT_SECRET_KEY=your_super_secret_jwt_key_at_least_32_characters_long

# Email Service (SMTP)
SMTP_USER=your_email@gmail.com
SMTP_APP_PASS=your_gmail_app_password

# ImageKit Configuration (IK)
IK_URL=https://ik.imagekit.io/your_imagekit_id/
IK_PUB_KEY=public_your_imagekit_public_key=
IK_PRI_KEY=private_your_imagekit_private_key=